# ---------------------------------------------------------------------------
# BahaAI — Docker configuration (OPTIONAL)
# ---------------------------------------------------------------------------
# You do NOT need this file to run the app — it works out of the box with
# sensible defaults. Only use it if you want to change something.
#
# HOW TO USE:
#   1. Copy this file to ".env" in the same folder as docker-compose.yml:
#         cp .env.docker.example .env      (macOS/Linux)
#         copy .env.docker.example .env    (Windows)
#   2. Edit the values below.
#   3. Run:  docker compose up --build
#
# Docker Compose reads ".env" automatically. Anything you leave out here
# falls back to the default shown in the comment.
# ---------------------------------------------------------------------------

# --- Web address / port -----------------------------------------------------
# The port on YOUR computer where the app is served.
# If port 8000 is already used by another app, change this to e.g. 8080,
# then open http://localhost:8080  (remember to update APP_URL too).
APP_PORT=8000
APP_URL=http://localhost:8000

# App display name and debug mode.
APP_NAME=BahaAI
APP_DEBUG=true

# --- Database ---------------------------------------------------------------
# These configure the bundled PostgreSQL container. The app and the database
# are kept in sync automatically. You normally don't need to change these.
DB_DATABASE=baha_ai
DB_USERNAME=baha
DB_PASSWORD=secret

# --- Weather (optional) -----------------------------------------------------
# Paste a free OpenWeatherMap API key to show LIVE weather.
# Get one at: https://openweathermap.org/api
# Leave blank to use realistic SIMULATED weather (the app works either way).
OPENWEATHERMAP_API_KEY=
